    {
      "name": "Parcel",
      "item": [
        {
          "name": "Create Parcel (multipart)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "const p = r && r.data ? (r.data._id || (r.data.parcel && r.data.parcel._id)) : null;",
              "if (p) pm.collectionVariables.set('parcel_id', p);"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "formdata", "formdata": [
              { "key": "data", "value": "{\n  \"parcel_name\": \"Electronics Package\",\n  \"size\": \"medium\",\n  \"vehicle_type\": \"sedan\",\n  \"weight\": 2.5,\n  \"pickup_location\": { \"address\": \"123 Main Street\", \"latitude\": 40.7128, \"longitude\": -74.0060 },\n  \"handover_location\": { \"address\": \"456 Oak Avenue\", \"latitude\": 40.7580, \"longitude\": -73.9855 },\n  \"priority\": \"normal\",\n  \"date\": \"2026-07-15\",\n  \"time\": \"14:30\",\n  \"receiver_name\": \"John Doe\",\n  \"receiver_phone\": \"+1234567890\",\n  \"sender_remarks\": \"Handle with care\"\n}", "type": "text" },
              { "key": "parcel_images", "type": "file", "src": [] }
            ] },
