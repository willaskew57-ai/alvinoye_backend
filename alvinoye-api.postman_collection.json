        },
        {
          "name": "Propose Price (Admin)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "if (r && r.data && r.data._id) { pm.collectionVariables.set('price_request_id', r.data._id); console.log('price_request_id saved:', r.data._id); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"parcel_id\": \"{{parcel_id}}\",\n  \"proposed_price\": 150.50,\n  \"message\": \"Initial price estimate\"\n}" },
            "url": { "raw": "{{base_url}}/parcel/propose-price", "host": ["{{base_url}}"], "path": ["parcel", "propose-price"] },
            "description": "ADMIN. Saves price_request_id (the proposal's _id) used by Accept/Reject Price."
          }
        },
        {
          "name": "Reject and Counter (Customer)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "if (r && r.data && r.data._id) { pm.collectionVariables.set('price_request_id', r.data._id); console.log('price_request_id saved:', r.data._id); }"
            ] } }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"parcel_id\": \"{{parcel_id}}\",\n  \"rejection_reason\": \"Price is too high\",\n  \"suggested_price\": 120.00\n}" },
            "url": { "raw": "{{base_url}}/parcel/reject-and-counter/{{parcel_id}}", "host": ["{{base_url}}"], "path": ["parcel", "reject-and-counter", "{{parcel_id}}"] },
            "description": "CUSTOMER counter-offer. Saves the new price_request_id."
          }
        },
        {
          "name": "Admin Final Offer",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
