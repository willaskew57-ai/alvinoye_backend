{
  "info": {
    "name": "Alvinoye Backend - Full API",
    "description": "Complete API collection for the Alvinoye parcel-delivery backend.\n\n## Getting started\n1. Set the `root_url` variable (default http://localhost:5000). `base_url` is `{{root_url}}/api/v1`.\n2. Run a login under **Auth** (Login Customer / Admin / Driver). The token is auto-saved to `access_token` and used by every protected request (collection-level Bearer auth).\n3. Fill id variables (`parcel_id`, `user_id`, `payment_id`, `chat_id`, `notification_id`, `review_id`, `faq_id`) as you go.\n\n## Notes\n- Protected routes use collection-level Bearer `{{access_token}}`. Public routes override to No Auth.\n- Multipart routes (parcel create/update, profile update, driver info, chat send) send a `data` text field with a JSON string plus file fields.\n- Payment test card (DPO): 4012888888881881  Exp 12/26  CVV 1234.\n- 'Track Driver' endpoints are included but the module is NOT mounted in routes/index.ts yet — they will 404 until registered.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "root_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "base_url", "value": "http://localhost:5000/api/v1", "type": "string" },
    { "key": "customer_email", "value": "customer@example.com", "type": "string" },
    { "key": "customer_password", "value": "123456", "type": "string" },
    { "key": "admin_email", "value": "admin@example.com", "type": "string" },
    { "key": "admin_password", "value": "123456", "type": "string" },
    { "key": "driver_email", "value": "driver@example.com", "type": "string" },
    { "key": "driver_password", "value": "123456", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "user_id", "value": "", "type": "string" },
    { "key": "parcel_id", "value": "", "type": "string" },
    { "key": "payment_id", "value": "", "type": "string" },
    { "key": "dpo_token", "value": "", "type": "string" },
    { "key": "chat_id", "value": "", "type": "string" },
    { "key": "notification_id", "value": "", "type": "string" },
    { "key": "review_id", "value": "", "type": "string" },
    { "key": "price_request_id", "value": "", "type": "string" },
    { "key": "faq_id", "value": "", "type": "string" },
    { "key": "recipient_id", "value": "", "type": "string" },
    { "key": "driver_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"CUSTOMER\"\n}" },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
            "description": "Public. role: SUPER_ADMIN | ADMIN | CUSTOMER | DRIVER. password min 6."
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "if (r && r.data && r.data.accessToken) { pm.collectionVariables.set('access_token', r.data.accessToken); }",
              "if (r && r.data && r.data.user && r.data.user._id) { pm.collectionVariables.set('user_id', r.data.user._id); }",
              "pm.test('login ok', () => pm.expect(pm.response.code).to.eql(200));"
            ] } }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{customer_email}}\",\n  \"password\": \"{{customer_password}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Saves access_token + user_id."
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "if (r && r.data && r.data.accessToken) { pm.collectionVariables.set('access_token', r.data.accessToken); }",
              "pm.test('login ok', () => pm.expect(pm.response.code).to.eql(200));"
            ] } }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login (Driver)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const r = pm.response.json();",
              "if (r && r.data && r.data.accessToken) { pm.collectionVariables.set('access_token', r.data.accessToken); }",
              "pm.test('login ok', () => pm.expect(pm.response.code).to.eql(200));"
            ] } }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{driver_email}}\",\n  \"password\": \"{{driver_password}}\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/logout", "host": ["{{base_url}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"otp\": \"123456\",\n  \"purpose\": \"REGISTER\"\n}" },
            "url": { "raw": "{{base_url}}/auth/verify-otp", "host": ["{{base_url}}"], "path": ["auth", "verify-otp"] },
            "description": "Auth required. otp = 6 digits. purpose: REGISTER | RESET_PASSWORD."
          }
        },
        {
          "name": "Resend OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"purpose\": \"REGISTER\"\n}" },
            "url": { "raw": "{{base_url}}/auth/resend-otp", "host": ["{{base_url}}"], "path": ["auth", "resend-otp"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"old_password\": \"password123\",\n  \"new_password\": \"newpassword456\"\n}" },
            "url": { "raw": "{{base_url}}/auth/change-password", "host": ["{{base_url}}"], "path": ["auth", "change-password"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/refresh-token", "host": ["{{base_url}}"], "path": ["auth", "refresh-token"] },
            "description": "Uses refresh_token cookie set during login."
          }
        },
        {
          "name": "Forget Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/forget-password", "host": ["{{base_url}}"], "path": ["auth", "forget-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"new_password\": \"newpassword456\"\n}" },
            "url": { "raw": "{{base_url}}/auth/reset-password", "host": ["{{base_url}}"], "path": ["auth", "reset-password"] },
            "description": "Auth required (after OTP verification)."
          }
        }
      ]
    },
