# ===============================
# App Environment
# ===============================
NODE_ENV=development
PORT=5000

# ===============================
# Database
# ===============================
# Local MongoDB
DATABASE_URI=mongodb://localhost:27017/parcel_delivery

# Production (MongoDB Atlas)
# DATABASE_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@cluster0.xxxxx.mongodb.net/parcel_delivery

# ===============================
# Security
# ===============================
BCRYPT_SALT_ROUNDS=10

# ===============================
# JWT Configuration
# ===============================
JWT_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_RESET_SECRET=your_jwt_reset_secret

# Expiry Times (in milliseconds)
# 30 Days
JWT_ACCESS_EXPIRES_IN=2592000000
# 7 Days
JWT_REFRESH_EXPIRES_IN=604800000
# 5 Minutes
JWT_RESET_EXPIRES_IN=300000

OTP_EXPIRY_MINUTES=5

# ===============================
# SMTP / Email Configuration
# ===============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SERVICE=gmail
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SERVICE_NAME="Parcel Delivery Support"

# ===============================
# Stripe Configuration
# ===============================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ===============================
# Google Maps API
# ===============================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ===============================
# AWS S3 (Image & Document Upload)
# ===============================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name

